{
  "installCommand": "npm install --prefix Backend && npm install --prefix Frontend/demiwal",
  "buildCommand": "npm run build --prefix Frontend/demiwal",
  "outputDirectory": "Frontend/demiwal/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...all]"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}