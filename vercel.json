{
  "installCommand": "cd Frontend/demiwal && npm install && cd ../../Backend && npm install",
  "buildCommand": "cd Frontend/demiwal && npm run build",
  "outputDirectory": "Frontend/demiwal/dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}